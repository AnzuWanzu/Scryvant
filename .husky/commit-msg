commit_message_file="$1"
# Read first line for normal validation, and full message for detecting auto-generated commits
commit_message="$(head -n 1 "$commit_message_file")"
full_commit_message="$(cat "$commit_message_file")"

RED='\033[1;31m'       # Bold Red
YELLOW='\033[1;33m'    # Bold Yellow
CYAN='\033[1;36m'      # Bold Cyan
DIM='\033[2m'          # Dimmed/Grey text
NC='\033[0m'           # No Color (Reset)

# If this is a Git-generated merge or revert commit message, skip validation
if printf '%s\n' "$full_commit_message" | grep -Eq '^(Merge |Revert )' || printf '%s\n' "$full_commit_message" | grep -q 'This reverts commit'; then
    echo -e "${YELLOW}⚠️  [Husky] Detected merge/revert commit — skipping commit message validation.${NC}"
    exit 0
fi

if ! npx --no-install commitlint --edit "$commit_message_file"; then
    echo -e "${RED}❌ [Husky] commitlint validation failed. Follow the project's commit message rules.${NC}"
    echo -e "See commitlint.config.js for the enforced format and allowed types."
    exit 1
fi